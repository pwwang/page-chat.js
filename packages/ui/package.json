    "homepage": "https://alibaba.github.io/page-chat/",
    "scripts": {
        "build": "vite build",
        "prepublishOnly": "node -e \"const fs=require('fs');['LICENSE'].forEach(f=>fs.copyFileSync('../../'+f,f))\"",
